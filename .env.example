# VoxCraft Configuration
# Copy this file to .env and adjust values as needed.

# Server
VOXCRAFT_HOST=127.0.0.1
VOXCRAFT_PORT=8765

# Data directory for exports, history, and database
VOXCRAFT_DATA_DIR=./data

# Logging level: DEBUG, INFO, WARNING, ERROR
VOXCRAFT_LOG_LEVEL=INFO

# Max concurrent synthesis jobs in batch mode
VOXCRAFT_MAX_CONCURRENCY=4

# Supertonic auto-download (set to false for air-gapped deployments)
SUPERTONIC_AUTO_DOWNLOAD=true
